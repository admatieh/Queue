{
  "name": "asset-linker",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build && cross-env NODE_ENV=production tsx -r dotenv/config server/index.ts",
    "dev:split": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development tsx -r dotenv/config server/index.ts",
    "dev:client": "vite --force",
    "build": "vite build",
    "build:full": "tsx -r dotenv/config script/build.ts",
    "clean": "node --eval \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "cross-env NODE_ENV=production tsx -r dotenv/config server/index.ts",
    "seed": "tsx -r dotenv/config server/seed.ts",
    "db:seed": "tsx -r dotenv/config server/seed.ts",
    "db:reset": "tsx -r dotenv/config server/seed.ts --reset",
    "check": "tsc"
  },
