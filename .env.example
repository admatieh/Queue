# QueueBuddy — Environment Variables

# ─── Required ───────────────────────────────────────────────────────────────

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/queuebuddy

# Session secret — MUST be a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_me_in_production_to_a_64_char_random_string

# ─── Optional ───────────────────────────────────────────────────────────────

# Server port (default: 5000)
PORT=5000

# Google Maps Embed API key (enables live venue maps on seat-map pages)
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Development only ────────────────────────────────────────────────────────

# Set to "development" for hot reload / verbose logs
NODE_ENV=development
